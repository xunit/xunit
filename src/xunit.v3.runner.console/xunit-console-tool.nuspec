<?xml version="1.0" encoding="utf-8"?>
<package>
	<metadata>
		<id>xunit-console-tool</id>
		<version>$PackageVersion$</version>
		<title>.NET tool for xunit-console</title>
		<authors>jnewkirk,bradwilson</authors>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="expression">Apache-2.0</license>
		<licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
		<icon>_content/logo-128-transparent.png</icon>
		<readme>_content/README.md</readme>
		<releaseNotes>https://xunit.net/releases/v3/$PackageVersion$</releaseNotes>
		<description>xunit.v3.runner.console, provided as a dotnet tool ('xunit-console'). Supports Windows (on x86, x64, and Arm), Linux (on x64, AArch32, and AArch64), and macOS (on Intel and Apple Silicon).</description>
		<copyright>Copyright (C) .NET Foundation</copyright>
		<repository type="git" url="https://github.com/xunit/xunit" commit="$GitCommitId$" />
		<packageTypes>
			<packageType name="DotnetTool" />
		</packageTypes>
	</metadata>
	<files>
		<file target="_content\" src="..\..\tools\media\logo-128-transparent.png" />
		<file target="_content\README.md" src="obj\xunit-console-tool.README.md" />

		<file target="tools\net10.0\any\" src="Package\tools\net10.0\any\*" />
	</files>
</package>
