<?xml version="1.0" encoding="utf-8"?>
<package>
	<metadata>
		<id>xunit.v3.runner.inproc.console.aot</id>
		<version>$PackageVersion$</version>
		<title>xUnit.net v3 [Runner: In-Process Console (Native AOT compatible)]</title>
		<authors>jnewkirk,bradwilson</authors>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<license type="expression">Apache-2.0</license>
		<licenseUrl>https://licenses.nuget.org/Apache-2.0</licenseUrl>
		<icon>_content/logo-128-transparent.png</icon>
		<readme>_content/README.md</readme>
		<releaseNotes>https://xunit.net/releases/v3/$PackageVersion$</releaseNotes>
		<description>In-process console runner for xUnit.net framework, providing the entrypoint for self-executing unit tests. Supports .NET 8 or later.</description>
		<copyright>Copyright (C) .NET Foundation</copyright>
		<repository type="git" url="https://github.com/xunit/xunit" commit="$GitCommitId$" />
		<dependencies>
			<group targetFramework="net8.0">
				<dependency id="xunit.v3.extensibility.core.aot" version="[$PackageVersion$]" />
				<dependency id="xunit.v3.runner.common.aot" version="[$PackageVersion$]" />
			</group>
		</dependencies>
	</metadata>
	<!-- Remember to update tools\builder\targets\SignAssemblies.cs when assemblies are added or removed -->
	<files>
		<file target="_content\" src="..\..\tools\media\logo-128-transparent.png" />
		<file target="_content\README.md" src="obj\xunit.v3.runner.inproc.console.aot.README.md" />

		<file target="lib\net8.0\" src="bin\$Configuration$\net8.0\$SignedPath$xunit.v3.runner.inproc.console.aot.dll" />
		<file target="lib\net8.0\" src="bin\$Configuration$\net8.0\xunit.v3.runner.inproc.console.aot.xml" />
	</files>
</package>
