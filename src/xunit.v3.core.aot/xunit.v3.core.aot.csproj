<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <DefineConstants>$(DefineConstants);XUNIT_ARGUMENTFORMATTER_PRIVATE</DefineConstants>
    <NoWarn>$(NoWarn);NU5100</NoWarn>
    <RootNamespace>Xunit.v3</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)\..\xunit.v3.core\**\*.cs" Exclude="**\*_reflection.cs;**\obj\**\*.cs;**\Package\**\*" />
    <Compile Include="..\common\DotNetApiPolyfills.cs" LinkBase="Common" />
    <Compile Include="..\xunit.v3.assert\Asserts\Sdk\ArgumentFormatter.cs" />
    <Compile Include="..\xunit.v3.assert\Asserts\Sdk\ArgumentFormatter_aot.cs" />
    <Compile Include="..\common\MessagePartials\**\*.cs" LinkBase="Common\MessagePartials" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\xunit.v3.common.aot\xunit.v3.common.aot.csproj" />
  </ItemGroup>

</Project>
